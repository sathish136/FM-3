    "expo": "~54.0.34",
    "expo-camera": "~16.0.18",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "metro-runtime": "^0.84.4",
    "react": "catalog:",
    "react-dom": "catalog:",
